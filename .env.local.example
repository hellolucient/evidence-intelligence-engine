# LLM provider (OpenAI). Optional: add ANTHROPIC_API_KEY and switch in engine/llm/provider.ts
OPENAI_API_KEY=your_openai_api_key_here

# Supabase (EIE v2 persistence — Phase 2 schema in supabase/migrations/)
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
# Service role: server-only. Never expose to the browser or commit to git.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Optional: anon key for future client-side reads (RLS-protected). Not used by the MVP yet.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Persist completed analyses to Supabase (false / unset = off). If true without Supabase URL + service role, persistence is skipped with a server warning (§6.1).
# EIE_PERSIST_ANALYSIS=false

# Phase 5: optional tier models for the model router. If unset, all tasks fall back to the default model ("gpt-4o-mini").
# EIE_OPENAI_MODEL_CHEAP=gpt-4o-mini
# EIE_OPENAI_MODEL_REASONING=gpt-4o
# EIE_OPENAI_MODEL_PREMIUM=gpt-4.1

# Optional: PubMed E-utilities (no key required for basic use)
# Set this to your email address for better rate limits
PUBMED_EMAIL=your@email.com

# Optional: Semantic Scholar API Key (free, recommended for better rate limits)
# Get a free API key at: https://www.semanticscholar.org/product/api
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here
